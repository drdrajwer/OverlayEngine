<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OverlayEngine.UI.ViewModels"
             x:Class="OverlayEngine.UI.Views.PillView"
             x:DataType="vm:MainOverlayViewModel">

    <Border Background="#F5040404"
            CornerRadius="21"
            BoxShadow="0 8 40 0 #BB000000, 0 2 6 0 #44000000"
            ClipToBounds="True">

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Height="42"
                    Margin="16,0,12,0"
                    Spacing="0">

            <!-- ── CPU + GPU ─────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowCpuGpu}">

                <TextBlock Text="CPU"
                           FontSize="8" FontFamily="Inter,Roboto,sans-serif"
                           FontWeight="Medium" LetterSpacing="1"
                           Foreground="#55FFFFFF" VerticalAlignment="Center" />

                <TextBlock Text="{Binding CpuGpu.CpuTemp, StringFormat={}{0:F0}°}"
                           FontSize="14" FontWeight="Bold"
                           FontFamily="JetBrains Mono,Consolas,monospace"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" />

                <TextBlock Text="{Binding CpuGpu.CpuLoad, StringFormat={}{0:F0}%}"
                           FontSize="9" FontFamily="Inter,Roboto,sans-serif"
                           Foreground="#44FFFFFF" VerticalAlignment="Bottom"
                           Margin="0,0,0,2" />

                <Border Width="1" Height="14" Background="#22FFFFFF"
                        VerticalAlignment="Center" Margin="6,0" />

                <TextBlock Text="GPU"
                           FontSize="8" FontFamily="Inter,Roboto,sans-serif"
                           FontWeight="Medium" LetterSpacing="1"
                           Foreground="#55FFFFFF" VerticalAlignment="Center" />

                <TextBlock Text="{Binding CpuGpu.GpuTemp, StringFormat={}{0:F0}°}"
                           FontSize="14" FontWeight="Bold"
                           FontFamily="JetBrains Mono,Consolas,monospace"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" />

                <TextBlock Text="{Binding CpuGpu.GpuLoad, StringFormat={}{0:F0}%}"
                           FontSize="9" FontFamily="Inter,Roboto,sans-serif"
                           Foreground="#44FFFFFF" VerticalAlignment="Bottom"
                           Margin="0,0,0,2" />
            </StackPanel>

            <Border Width="1" Height="18" Background="#1AFFFFFF"
                    VerticalAlignment="Center" Margin="10,0"
                    IsVisible="{Binding ShowCpuGpu}" />

            <!-- ── Mikrofon ───────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="5"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowAudio}">

                <TextBlock Text="🎙" FontSize="13" VerticalAlignment="Center"
                           IsVisible="{Binding !Audio.IsMuted}" />
                <TextBlock Text="🔇" FontSize="13" VerticalAlignment="Center"
                           IsVisible="{Binding Audio.IsMuted}" />

                <TextBlock Text="{Binding Audio.MicVolumeDb, StringFormat={}{0:F0}dB}"
                           FontSize="11" FontFamily="JetBrains Mono,Consolas,monospace"
                           Foreground="#77FFFFFF" VerticalAlignment="Center" />
            </StackPanel>

            <Border Width="1" Height="18" Background="#1AFFFFFF"
                    VerticalAlignment="Center" Margin="10,0"
                    IsVisible="{Binding ShowAudio}" />

            <!-- ── Sieć ───────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowNetwork}">
                <TextBlock Text="↓"
                           FontSize="11" FontWeight="Bold"
                           Foreground="#4FC3F7" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Network.DownloadLabel}"
                           FontSize="11" FontFamily="JetBrains Mono,Consolas,monospace"
                           Foreground="#88FFFFFF" VerticalAlignment="Center" />
                <TextBlock Text="↑"
                           FontSize="11" FontWeight="Bold"
                           Foreground="#CE93D8" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Network.UploadLabel}"
                           FontSize="11" FontFamily="JetBrains Mono,Consolas,monospace"
                           Foreground="#77FFFFFF" VerticalAlignment="Center" />
            </StackPanel>

            <Border Width="1" Height="18" Background="#1AFFFFFF"
                    VerticalAlignment="Center" Margin="10,0"
                    IsVisible="{Binding ShowNetwork}" />

            <!-- ── Notatki ────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="5"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowNotes}">
                <TextBlock Text="📝" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Notes.NoteCount}"
                           FontSize="12" FontFamily="JetBrains Mono,Consolas,monospace"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Border Width="1" Height="18" Background="#1AFFFFFF"
                    VerticalAlignment="Center" Margin="10,0"
                    IsVisible="{Binding ShowNotes}" />

            <!-- ── Now Playing ───────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="5"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowNowPlaying}">
                <TextBlock Text="♫"
                           FontSize="12"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding NowPlaying.IsPlaying}" />
                <TextBlock Text="{Binding NowPlaying.Title}"
                           FontSize="11"
                           FontFamily="Inter,Roboto,sans-serif"
                           Foreground="#88FFFFFF"
                           VerticalAlignment="Center"
                           MaxWidth="120"
                           TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding NowPlaying.IsPlaying}" />
                <TextBlock Text="—"
                           FontSize="11"
                           Foreground="#44FFFFFF"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !NowPlaying.IsPlaying}" />
            </StackPanel>

            <!-- ── Przycisk ustawień ─────────────────────────────── -->
            <Border Width="1" Height="18" Background="#1AFFFFFF"
                    VerticalAlignment="Center" Margin="10,0" />

            <Button Classes="icon-btn"
                    Content="⚙"
                    FontSize="13"
                    VerticalAlignment="Center"
                    Padding="4,0"
                    Command="{Binding Notes.ShowSettingsCommand}"
                    ToolTip.Tip="Ustawienia" />

        </StackPanel>
    </Border>
</UserControl>
